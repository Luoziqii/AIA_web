# .env.example
# 这是环境变量模板文件。请勿在此文件中填写真实的生产环境敏感信息！

# ==========================================
# 核心安全配置 (🚨 必须配置，无默认值，缺失即崩溃)
# ==========================================

# JWT 签名密钥 (用于签发与校验登录 Token)
# 建议长度至少 32 字符。可以使用命令生成: openssl rand -base64 32
JWT_SECRET=

# 终极管理员动态口令密钥 (用于校验你的极客动态密码)
# 必须是有效的 Base64 字符串。
# 首次生成方法: 直接运行 `go run cmd/totp/main.go`，它会自动为你生成一个高强度的 Base64 密钥。
DYNAMIC_SECRET=

# ==========================================
# 数据库配置
# ==========================================
DB_USER=root
DB_PASS=114514
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ArticleDB

# ==========================================
# 静态资源存储配置
# ==========================================
# 存储引擎选择: local 或 cos (代码底层为 COSStorage)
STORAGE_ENGINE=local

# 腾讯云 COS 配置（仅 STORAGE_ENGINE=cos 时必须有效）
COS_BUCKET_URL=
COS_SECRET_ID=
COS_SECRET_KEY=