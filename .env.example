# ---- 鉴权 ----
# JWT 签名密钥
# 生成方法: go run cmd/totp/main.go -generate-key
JWT_SECRET=change-me-in-production

# TOTP 动态码密钥
# 生成方法: go run cmd/totp/main.go -generate-key
TOTP_ECC_KEY=change-me-in-production

# ---- 数据库 ----
DB_USER=root
DB_PASS=114514
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=BlogData

# ---- 存储 ----
# 选择存储引擎: local 或 oss
STORAGE_ENGINE=local

# 本地存储路径（仅 STORAGE_ENGINE=local 时有效）
LOCAL_STORAGE_PATH=./uploads

# 腾讯云 COS 配置（仅 STORAGE_ENGINE=oss 时有效）
COS_BUCKET_URL=YOUR_BUCKET_URL
COS_SECRET_ID=YOUR_SECRET_ID
COS_SECRET_KEY=YOUR_SECRET_KEY